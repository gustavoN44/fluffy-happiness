# Copy to .env and fill in. docker-compose and the app both read .env.

# --- Postgres (consumed by docker-compose) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_PORT=5432

# --- Application config ---
# Connection string the Python app uses to reach the dockerized Postgres.
# Must match the POSTGRES_* values above.
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# OpenAI API key for embeddings (text-embedding-3-small) and generation.
OPENAI_API_KEY=sk-...
